function [] = droneArmCalculations(materials)
%Obtains a detailed summary of the drone arm dimensions, including length,
%width, height, thickness, shape, and material. Outputs the armMass, total
%DroneMass, and maxPayLoad.

%Get dimension values from user
armLength = input('What is the length of each arm in cm: ');
armWidth = input('What is the width of each arm in cm: ');
armHeight = input('What is the height of each arm in cm: ');

%Get drone arm shape from user
options = {"rectangular", "triangular"};
[index, tf] = listdlg('PromptString', 'Select a shape:', ...
                     'SelectionMode', 'single', ...
                     'ListString', options);

if tf
    shape = options{index};
    disp(['User chose: ' shape]);
end

%Get material type from user
options = {materials.name};
[index, tf] = listdlg('PromptString', 'Select a material:', ...
                     'SelectionMode', 'single', ...
                     'ListString', options);

if tf
    material = options{index};
    disp(['User chose: ' material]);
end

%Use the inputted material to find the corresponding information
idx = find([materials.name] == material);
cost = materials(idx).cost_USD_per_m;
density = materials(idx).rho_kg_m3;
modulus = materials(idx).E_Pa;
poissons = materials(idx).nu;
yieldStrength = materials(idx).yieldStrength_Pa;

% Calculate the armVolume based on the dimensions
if shape == "rectangular"
    armVolume = armLength * armWidth * armHeight;    
elseif shape == "triangular"
    armVolume = (armLength * armWidth * armHeight) /2;
end

fprintf('The volume of the arm is %.4f cm^3\n', armVolume);

 %Calculate the cost based on the material and dimensions
 armCost = armLength * (10.^-2) * cost;
 totalCost = armCost*4;

 fprintf('The total cost of the drone is %.4f dollars\n', totalCost);

 %Calculate the total drone mass based on material density and arm volume
 armMass = armVolume * (10.^-6) * density;
 totalDroneMass = (4 * armMass) + 1;

 fprintf('The total mass of the drone is %.4f kg\n', totalDroneMass);

 %Find max payload and check if it meets project requirements
 maxPayLoad = 2 - totalDroneMass;

 if maxPayLoad <0.5
     disp('Drone does not meet minimum payload requirements');
 else
     fprintf('The drone can carry a maximum load of %.4f kg\n', maxPayLoad);
 end

end
